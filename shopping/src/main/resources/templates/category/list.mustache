{{> layout/header }}
{{> layout/nav }}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">카테고리 목록</h2>
        <a href="/categories/save-form" class="btn">
            + 카테고리 등록
        </a>
    </div>

    <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-light">
        <tr>
            <th style="width: 10%">ID</th>
            <th style="width: 45%">카테고리명</th>
            <th style="width: 45%">상위 카테고리</th>
        </tr>
        </thead>

        <tbody>
        {{#categories}}
            <tr>
                <td>{{id}}</td>
                <td class="text-start ps-3">{{categoryName}}</td>
                <td>
                    {{#parent}}
                        {{categoryName}}
                    {{/parent}}
                    {{^parent}}
                        <span class="text-muted">최상위</span>
                    {{/parent}}
                </td>
            </tr>
        {{/categories}}

        {{^categories}}
            <tr>
                <td colspan="3" class="text-center text-muted py-4">
                    등록된 카테고리가 없습니다.
                </td>
            </tr>
        {{/categories}}
        </tbody>
    </table>
</div>

{{> layout/footer }}