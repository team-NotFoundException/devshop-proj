{{> layout/header }}


<main class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <section class="content-section">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>카테고리 전체 목록</h2>
            <a href="/admin/categories/save" class="btn btn-dark">카테고리 등록하러 가기</a>
        </div>

        <table class="data-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>분류</th>
                <th>카테고리 명</th>
                <th>상위 카테고리</th>
                <th>노출 순서</th>
                <th>관리</th>
            </tr>
            </thead>
            <tbody>
            {{#categories}}
                <tr>
                    <td>{{id}}</td>
                    <td>
                        <span class="badge
                            {{#parentName}}bg-info-dark{{/parentName}}
                            {{^parentName}}bg-primary-dark{{/parentName}}">
                            {{#parentName}}소분류{{/parentName}}
                            {{^parentName}}대분류{{/parentName}}
                        </span>
                    </td>
                    <td class="fw-bold">{{categoryName}}</td>
                    <td>
                        {{#parentName}}{{parentName}}{{/parentName}}
                        {{^parentName}}-{{/parentName}}
                    </td>
                    <td>
                        {{displayOrder}}
                    </td>
                    <td>
                        <div class="d-flex gap-2">
                            <a href="/admin/categories/{{id}}/edit" class="btn-sm btn-edit text-decoration-none">수정</a>
                            <form action="/admin/categories/{{id}}/delete" method="post" onsubmit="return confirm('정말 삭제하시겠습니까?')">
                                <button type="submit" class="btn-sm btn-delete" style="border:none;">삭제</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {{/categories}}
            {{^categories}}
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">등록된 카테고리가 없습니다.</td>
                </tr>
            {{/categories}}
            </tbody>
        </table>
    </section>
</main>

{{> layout/footer}}