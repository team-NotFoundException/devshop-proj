
        {{> layout/header }}


<div class="container mt-5">
    <!-- 카테고리 헤더 -->
    <div class="category-header text-center mb-5">
        <a href="/" class="btn btn-outline-secondary mb-3">
            <i class="fas fa-arrow-left"></i> 메인으로
        </a>
        <h2 class="category-title">{{category.categoryName}}</h2>
        <p class="text-muted">{{category.categoryName}} 카테고리의 상품입니다</p>
    </div>

    <!-- 상품 그리드 -->
    <div class="product-grid">
        {{#products}}
            <div class="product-card">
                <a href="/products/{{id}}" class="card-link">
                    <div class="card-image">
                        {{#thumbnailUrl}}
                            <img src="{{thumbnailUrl}}" alt="{{name}}">
                        {{/thumbnailUrl}}
                        {{^thumbnailUrl}}
                            <img src="/img/no-image.png" alt="이미지 없음">
                        {{/thumbnailUrl}}
                    </div>
                    <div class="card-body">
                        <div class="owner-info">
                            <small class="text-muted"><i class="fas fa-store"></i> {{ownerName}}</small>
                        </div>
                        <h3 class="product-title">{{name}}</h3>
                        <div class="price-section">
                            <span class="price-value">{{price}}</span><span class="price-unit">원</span>
                        </div>
                    </div>
                </a>
                <div class="card-footer-action">
                    <button class="btn-add-cart" onclick="addCart({{id}})">담기</button>
                </div>
            </div>
        {{/products}}

        {{^products}}
            <div class="empty-state">
                <i class="fas fa-box-open fa-3x mb-3 text-muted"></i>
                <p>이 카테고리에는 아직 상품이 없습니다.</p>
                <a href="/" class="btn btn-primary mt-3">메인으로 돌아가기</a>
            </div>
        {{/products}}
    </div>
</div>

{{> layout/footer }}
