{{> layout/header}}

<main class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <section class="content-section">
        <div class="page-header">
            <div>
                <h2>카테고리 수정</h2>
                <p class="subtitle">카테고리 정보를 수정하세요</p>
            </div>
            <a href="/admin/categories/list" class="btn-back">
                <i class="bi bi-arrow-left"></i>
                목록으로
            </a>
        </div>

        <div class="form-card" style="max-width: 600px; margin: 0 auto;">
            <form action="/admin/categories/{{category.id}}/edit" method="post" class="category-form">

                <div class="form-group">
                    <label class="form-label">
                        <i class="bi bi-tag"></i>
                        카테고리명
                    </label>
                    <input type="text"
                           name="categoryName"
                           class="form-input"
                           value="{{category.categoryName}}"
                           required>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="bi bi-sort-numeric-down"></i>
                        노출 순서
                    </label>
                    <input type="number"
                           name="displayOrder"
                           class="form-input"
                           value="{{category.displayOrder}}"
                           min="0"
                           required>
                    <small class="form-hint">숫자가 작을수록 먼저 표시됩니다</small>
                </div>

                <div class="form-group">
                    <label class="form-label">분류 정보</label>
                    <div class="info-box">
                        <p><strong>현재 분류:</strong>
                            {{#category.parentName}}
                                소분류 (상위: {{category.parentName}})
                            {{/category.parentName}}
                            {{^category.parentName}}
                                대분류
                            {{/category.parentName}}
                        </p>
                    </div>
                </div>

                <div class="form-actions">
                    <a href="/admin/categories/list" class="btn-cancel">취소</a>
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-check-circle"></i>
                        수정 완료
                    </button>
                </div>
            </form>
        </div>
    </section>
</main>

<style>
    .admin-owner-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f8f9fa;
    }

    .content-section {
        flex: 1;
        padding: 30px;
        max-width: 1400px;
        margin: 0 auto;
        width: 100%;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .page-header h2 {
        font-size: 28px;
        font-weight: 700;
        color: #1a1a1a;
        margin: 0 0 4px 0;
    }

    .subtitle {
        color: #6b7280;
        font-size: 15px;
        margin: 0;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        color: #374151;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .btn-back:hover {
        border-color: #667eea;
        color: #667eea;
        transform: translateX(-4px);
    }

    .form-card {
        background: white;
        border-radius: 20px;
        padding: 32px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 10px;
    }

    .form-label i {
        color: #9ca3af;
        font-size: 16px;
    }

    .form-input {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        font-size: 15px;
        color: #1a1a1a;
        transition: all 0.3s ease;
        background: #f9fafb;
    }

    .form-input:focus {
        outline: none;
        border-color: #667eea;
        background: white;
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
    }

    .form-hint {
        display: block;
        margin-top: 8px;
        font-size: 13px;
        color: #6b7280;
    }

    .info-box {
        padding: 12px 16px;
        background: #f0f9ff;
        border-left: 4px solid #3b82f6;
        border-radius: 8px;
    }

    .info-box p {
        margin: 0;
        color: #1e40af;
        font-size: 14px;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
        justify-content: flex-end;
    }

    .btn-cancel, .btn-submit {
        padding: 14px 28px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-cancel {
        background: #f3f4f6;
        color: #6b7280;
    }

    .btn-cancel:hover {
        background: #e5e7eb;
        color: #374151;
    }

    .btn-submit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }
</style>

{{> layout/footer}}