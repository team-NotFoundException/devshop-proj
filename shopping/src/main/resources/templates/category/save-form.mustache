
        {{> layout/header }}


<main class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <section class="content-section">
        <h2>카테고리 관리 및 등록</h2>

        <div class="row mt-4">
            <div class="col-md-6">
                <div class="admin-table-container">
                    <h5>대분류 등록</h5>
                    <hr>
                    <form action="/admin/categories/parent-save" method="post">
                        <div class="mb-3">
                            <label class="form-label">카테고리 명</label>
                            <input type="text" name="categoryName" class="form-control" placeholder="예: 의류, 가전" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">노출 순서</label>
                            <input type="number" name="displayOrder" class="form-control" value="1" min="1">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">상위 카테고리 추가</button>
                    </form>
                </div>
            </div>

            <div class="col-md-6">
                <div class="admin-table-container">
                    <h5>소분류 등록</h5>
                    <hr>
                    <form action="/admin/categories/child-save" method="post">
                        <div class="mb-3">
                            <label class="form-label">상위 카테고리 선택</label>
                            <select name="parentId" class="form-select" required>
                                <option value="">대분류를 선택하세요</option>
                                {{#categories}}

                                        <option value="{{id}}">{{categoryName}}</option>

                                {{/categories}}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">카테고리 명</label>
                            <input type="text" name="categoryName" class="form-control" placeholder="예: 티셔츠, 바지" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">노출 순서</label>
                            <input type="number" name="displayOrder" class="form-control" value="1" min="1">
                        </div>
                        <button type="submit" class="btn btn-success w-100">하위 카테고리 추가</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>

{{> layout/footer}}