<!DOCTYPE html>
<html lang="en">
<head>
    <title>DEVSHOP | 개발자 필수템</title>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="icon" href="/favicon.ico">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/user/login-form.css">
    <link rel="stylesheet" href="/css/user/join-form.css">
    <link rel="stylesheet" href="/css/payment/payment.css">
    <link rel="stylesheet" href="/css/payment/payment-success.css">
    <link rel="stylesheet" href="/css/payment/payment-fail.css">
    <link rel="stylesheet" href="/css/cart/cart.css">
    <link rel="stylesheet" href="/css/admin-owner/style.css">
    <link rel="stylesheet" href="/css/product/card.css">
    <link rel="stylesheet" href="/css/product/main.css">
    <link rel="stylesheet" href="/css/user/admin-style.css">

<!-- 여기에 css 파일 만든것 붙일 것임! (각 도메인 폴더안에 생성하기!) -->
</head>
<body>

<header class="header-wrapper has-nav">
    <div class="container">
        <div class="first-top d-flex justify-content-end gap-3 py-2">
            <a href="#" class="text-secondary small">고객센터</a>
            {{#sessionUser}}
                <a href="/user/logout" class="text-secondary small">로그아웃</a>
            {{/sessionUser}}
            {{^sessionUser}}
                <a href="/user/login" class="text-secondary small">로그인</a>
            {{/sessionUser}}
        </div>

        <div class="second-top d-flex justify-content-between align-items-center py-3">
            <a href="/">
                <img src="/img/logo.png" width="180px" alt="logo"/>
            </a>
            <div class="d-flex align-items-center gap-3">
                <div class="greet small">
                    {{#sessionUser}}
                        <strong>{{sessionUser.nickname}}</strong>님, 안녕하세요!
                        <span class="badge bg-secondary">{{roleDisplay}}</span>
                    {{/sessionUser}}
                    {{^sessionUser}}DEV SHOP 입니다{{/sessionUser}}
                </div>
                {{#sessionUser}}
                    <a href="/user/update"><i class="bi bi-person-fill fs-4"></i></a>
                    {{^isAdmin}}
                        <a href="/cart/list"><i class="bi bi-cart fs-4"></i></a>
                    {{/isAdmin}}
                {{/sessionUser}}
            </div>
        </div>

        {{> layout/nav }}

    </div>
</header>
