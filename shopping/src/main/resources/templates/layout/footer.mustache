{{#sessionUser}}
<div id="floatingBanner" class="floating-banner">
    <div class="banner-content">
        <a href="/chatRoom/me">
            <div class="banner-icon"><i class="fa-solid fa-headset"></i></div>
        </a>
    </div>
</div>
{{/sessionUser}}

<style>
    .floating-banner {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 64px;
        height: 64px;
        background-color: #ffffff;
        border: 2px solid #D1D5DB;
        border-radius: 50%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.18);
        z-index: 1050;

        display: flex;
        justify-content: center;
        align-items: center;

        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .floating-banner:hover {
        transform: translateY(-6px);
        box-shadow: 0 14px 36px rgba(0,0,0,0.22);
    }

    /* 링크 전체 클릭 가능 */
    .floating-banner a {
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
    }

    /* 아이콘 */
    .banner-icon {
        font-size: 26px;
        color: #111;
        line-height: 1;
    }

    .banner-text small {
        display: block;
        font-size: 11px;
        color: #666;
    }

    .banner-text strong {
        font-size: 14px;
    }


    /* 링크 스타일 초기화 */
    .floating-banner a {
        text-decoration: none;
        display: block;
    }
</style>

<script>
    function closeBanner() {
        const banner = document.getElementById('floatingBanner');
        // 부드럽게 사라지는 효과
        banner.style.opacity = '0';
        banner.style.transform = 'scale(0.9)';
        setTimeout(() => {
            banner.style.display = 'none';
        }, 300);
    }
</script>

</body>
</html>