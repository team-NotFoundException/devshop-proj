<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>주소 검색</title>
</head>

<body>
<form id="jusoForm" method="post"
      action="https://business.juso.go.kr/addrlink/addrLinkUrl.do">

    <input type="hidden" name="confmKey" value="devU01TX0FVVEgyMDI1MTIzMTExNTM1NTExNzM3OTE=">
    <input type="hidden" name="resultType" value="4">
    <input type="hidden" name="returnUrl" value="{{returnUrl}}">
</form>

<script>
    (function () {
        const urlParams = new URLSearchParams(window.location.search);
        const inputYn = urlParams.get("inputYn");

        if (inputYn !== "Y") {
            // 최초 진입 → 주소검색 페이지로 POST
            document.getElementById("jusoForm").submit();
            return;
        }

        // 주소 선택 후 돌아온 경우
        const data = {
            zipNo: urlParams.get("zipNo"),
            roadAddr: urlParams.get("roadAddr"),
            addrDetail: urlParams.get("addrDetail")
        };

        opener.jusoCallBack(data);
        window.close();
    })();
</script>
</body>
</html>
