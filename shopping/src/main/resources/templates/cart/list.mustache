{{> layout/header }}


<main class="main-container">
    <h1 class="page-title">장바구니</h1>

    <!-- 테스트 폼들 (나중에 제거) -->
<!--    <div class="test-forms">-->
<!--        <form action="/cart/add" method="post" style="display:inline-block;">-->
<!--            <input type="number" name="productId" placeholder="상품ID" style="width: 80px; padding: 8px;" value=""-->
<!--                   required>-->
<!--            <input type="number" name="quantity" placeholder="수량" value="1" style="width: 60px; padding: 8px;" required>-->
<!--            <button type="submit" class="btn-test">아이템 추가</button>-->
<!--        </form>-->
<!--    </div>-->

    <div class="cart-layout">
        <!-- 왼쪽: 장바구니 상품 목록 -->
        <div class="cart-left">
            <div class="cart-header">
                <div class="tab active">
                    <span>DEV SHOP 배송</span>
                    <span class="count">{{cart.cartItems.size}}</span>
                </div>
            </div>

            <div class="select-all">
                <label class="checkbox-label">
                    <input type="checkbox" id="selectAll" onchange="toggleAllChecks(this.checked)">
                    <span class="checkmark"></span>
                    <span>전체 선택</span>
                </label>
                <form action="/cart/delete-checked" method="post" style="display:inline;">
                    <button type="submit" class="delete-btn" onclick="return confirm('선택한 상품을 삭제하시겠습니까?')">선택 삭제
                    </button>
                </form>
            </div>

            <!-- 상품 아이템 -->
            {{#cart.cartItems}}
                <div class="cart-item">
                    <label class="checkbox-label">
                        <input type="checkbox" class="item-checkbox"
                               {{#isChecked}}checked{{/isChecked}}  data-item-id="{{id}}"
                               onchange="toggleCheck({{id}}, this)">
                        <span class="checkmark"></span>
                    </label>

                    <div class="item-content">
                        <div class="item-image-wrapper">
                            <img class="item-image" src="{{product.thumbnailUrl}}" alt="">
                        </div>

                        <div class="item-details">
                            <div class="item-info">
                                <h3 class="item-brand">{{product.productName}}</h3>

                                <p class="item-desc">상품 코드: {{product.productCode}}</p>

                                <div class="item-meta">

                                    <div class="quantity">
                                        <button class="quantityBtn" onclick="updateOption({{id}}, -1)"><i
                                                class="fa-solid fa-minus"></i></button>
                                        <span class="item-quantity" data-cart-item-id="{{id}}" data-quantity="{{quantity}}">{{quantity}}개</span>
                                        <button class="quantityBtn" onclick="updateOption({{id}}, 1)"><i
                                                class="fa-solid fa-plus"></i></button>
                                    </div>

                                    <span class="badge-fast">빠른배송</span>
                                </div>
                            </div>

                            <div class="item-price">
                                <p class="price" data-total-price="{{id}}">{{totalPrice}}</p>
                            </div>
                        </div>

                        <div class="item-actions">
                            <form action="/cart/{{id}}/delete" method="post">
                                <button type="submit" class="btn-delete" onclick="return confirm('이 상품을 삭제하시겠습니까?')">
                                    <span>✕</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {{/cart.cartItems}}

            {{^cart.cartItems}}
                <div class="empty-cart">
                    <div class="empty-icon"><i class="fa-solid fa-cart-shopping"></i></div>
                    <p class="empty-text">장바구니가 비어있습니다</p>
                    <p class="empty-subtext">원하는 상품을 담아보세요</p>
                </div>
            {{/cart.cartItems}}
        </div>

        <!-- 오른쪽: 결제 정보 -->
        <div class="cart-right">
            <div class="payment-box">
                <h2 class="payment-title">주문 예상금액</h2>

                <div class="price-breakdown">
                    <div class="price-row">
                        <span class="label">총 상품금액</span>
                        <span class="value" id="productFinalPrice">{{cart.amount}}원</span>
                    </div>
                    <div class="price-row">
                        <span class="label">배송비</span>
                        <span class="value">0 원</span>
                    </div>
                    <div class="price-row">
                        <span class="label">검수비</span>
                        <span class="value free">무료</span>
                    </div>
                </div>

                <div class="total-price">
                    <span class="label">총 결제금액</span>
                    <span class="amount" id="finalPrice">{{cart.amount}}원</span>
                </div>


                <form action="/payment" method="get">
                    <input type="hidden" name="cartId" value="{{cart.id}}">
                    <button class="checkout-btn">주문하기</button>
                </form>

                <div class="benefit-info">
                    <p class="benefit-item"><i class="fa-regular fa-credit-card"></i> 네이버페이 4% 적립</p>
                    <p class="benefit-item"><i class="fa-solid fa-credit-card"></i> 롯데카드 3% 즉시할인</p>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    function toggleCheck(itemId, checkbox) {
        fetch(`/cart/${itemId}/update-check`, {
            method: 'POST'
        })
                .then(response => {
                    if (!response.ok) {
                        alert('오류가 발생했습니다.')
                    }
                    return response.json()
                })
                .then(data => {

                    updateSelectAllCheckbox();

                    const cartPrice = data.amount;
                    const totalPrice = cartPrice

                    document.getElementById('productFinalPrice').textContent =
                            cartPrice.toLocaleString() + '원';
                    document.getElementById('finalPrice').textContent =
                            totalPrice.toLocaleString() + '원';

                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('오류가 발생했습니다.');
                    checkbox.checked = !checkbox.checked;
                });
    }

    function toggleAllChecks(isChecked) {
        fetch(`/cart/toggle-all`, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                isChecked: isChecked
            })
        })
                .then(response => response.json())
                .then(data => {
                    document.querySelectorAll('.item-checkbox').forEach(checkbox => {
                        checkbox.checked = data.allChecked;
                    });
                    document.getElementById("productFinalPrice").textContent = data.amount.toLocaleString() + "원";
                    document.getElementById("finalPrice").textContent = data.amount.toLocaleString() + "원";

                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('오류가 발생했습니다.');
                });
    }

    function updateSelectAllCheckbox() {
        const allCheckbox = document.querySelectorAll('.item-checkbox');
        const selectAllCheckbox = document.getElementById('selectAll');

        if (selectAllCheckbox && allCheckbox.length > 0) {
            let allChecked = true;

            allCheckbox.forEach(checkbox => {
                if (!checkbox.checked) {
                    allChecked = false;
                }
            });

            selectAllCheckbox.checked = allChecked;
        }
    }

    function updateOption(cartItemId, number) {

        fetch(`/cart/${cartItemId}/update-option`, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                quantity: number
            })
        })
                .then(res => res.json())
                .then(data => {
                    document.querySelector(`.item-quantity[data-cart-item-id="${cartItemId}"]`).textContent = data.quantity.toLocaleString() + "개";
                    document.querySelector(`[data-total-price="${cartItemId}"]`).textContent = data.totalPrice.toLocaleString() + "원";
                    document.getElementById("productFinalPrice").textContent = data.amount.toLocaleString() + "원";
                    document.getElementById("finalPrice").textContent = data.amount.toLocaleString() + "원";
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('오류가 발생했습니다.');
                });
    }

    updateSelectAllCheckbox();

</script>
{{>layout/footer}}