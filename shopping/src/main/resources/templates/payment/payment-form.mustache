<div class="header-wrapper has-nav">
    <div class="container">
        {{> layout/header }}
        {{> layout/nav }}
    </div>
</div>

<main class="main-container">
    <div class="pay-container">
        <h1 class="pay-h1">결제하기</h1>

        {{#cartPayment}}
            <div class="cart-payment-section">
                <h2>주문 상품 정보</h2>

                <div class="payment-items">
                    {{#items}}
                        <div class="payment-item">
                            <div class="item-info">
                                <h3>{{productName}}</h3>
                                <p>상품코드: {{productCode}}</p>
                                <p>수량: {{quantity}}개</p>
                            </div>
                            <div class="item-price">
                                <p>단가: {{amount}}원</p>
                                <p class="total">합계: {{totalPrice}}원</p>
                            </div>
                        </div>
                    {{/items}}
                </div>

                <div class="payment-summary">
                    <div class="summary-row">
                        <span>총 상품금액</span>
                        <span class="amount">{{totalAmount}}원</span>
                    </div>
                    <div class="summary-row total">
                        <span>최종 결제금액</span>
                        <span class="amount">{{totalAmount}}원</span>
                    </div>
                </div>

                <form action="/order-create" method="post">
                    <div class="button-group">
                        <button type="submit" name="method" value="MOCK" class="btn-primary">{{totalAmount}}원 결제하기</button>
                        <button type="button" id="tossPayButton" class="btn-toss">
                            TossPay 결제하기
                        </button>
                        <a href="/cart/list" class="btn-secondary">장바구니로 돌아가기</a>
                    </div>
                </form>
            </div>
        {{/cartPayment}}

    </div>
</main>
{{>layout/footer}}

<script src="https://js.tosspayments.com/v1"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tossClientKey = "{{tossClientKey}}";
        const tossPayments = new TossPayments(tossClientKey);

        const button = document.getElementById("tossPayButton");
        if (button) {
            button.addEventListener("click", function () {
                const baseUrl = "{{baseUrl}}"
                const cartId = "{{cartPayment.cartId}}"
                const amount = parseInt("{{cartPayment.totalAmount}}", 10);
                const orderId = "ORD-" + new Date().getTime();

                const successUrl = `${baseUrl}/payment/cart/${cartId}/approve?method=TOSS_PAY`;
                const failUrl = `${baseUrl}/payment/cart/${cartId}/fail?method=TOSS_PAY`;

                try {
                    tossPayments.requestPayment("카드", {
                        amount: amount,
                        orderId: orderId,
                        orderName: "장바구니 상품 결제",
                        successUrl: successUrl,
                        failUrl: failUrl
                    })
                } catch (Error) {
                    console.error("결제 실패", Error);
                }
            });
        }
    });
</script>