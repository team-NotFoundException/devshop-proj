<div class="header-wrapper has-nav">
    <div class="container">
        {{> layout/header }}
        {{> layout/nav }}
    </div>
</div>

<main class="main-container">
    <div class="pay-container">
        <h1 class="pay-h1">결제하기</h1>

        {{#cartPayment}}
            <div class="cart-payment-section">
                <h2>주문 상품 정보</h2>

                <div class="payment-items">
                    {{#items}}
                        <div class="payment-item">
                            <div class="item-info">
                                <h3>{{productName}}</h3>
                                <p>상품코드: {{productCode}}</p>
                                <p>수량: {{quantity}}개</p>
                            </div>
                            <div class="item-price">
                                <p>단가: {{amount}}원</p>
                                <p class="total">합계: {{totalPrice}}원</p>
                            </div>
                        </div>
                    {{/items}}
                </div>

                <div class="payment-summary">
                    <div class="summary-row">
                        <span>총 상품금액</span>
                        <span class="amount">{{totalAmount}}원</span>
                    </div>
                    <div class="summary-row total">
                        <span>최종 결제금액</span>
                        <span class="amount">{{totalAmount}}원</span>
                    </div>
                </div>

                <form action="/order-create" method="post">
                    <div class="form-group">
                        <label for="method">결제 수단 선택</label>
                        <select id="method" name="method" required>
                            <option value="">결제 수단을 선택하세요</option>
                            <option value="MOCK">Mock 결제 (테스트)</option>
                            <option value="TOSS_PAY">Toss 결제</option>
                        </select>
                    </div>

                    <div class="button-group">
                        <button type="submit" class="btn-primary">{{totalAmount}}원 결제하기</button>
                        <a href="/cart/list" class="btn-secondary">장바구니로 돌아가기</a>
                    </div>
                </form>
            </div>
        {{/cartPayment}}

    </div>
</main>
{{>layout/footer}}