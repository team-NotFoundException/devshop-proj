<link rel="stylesheet" href="/css/review/inProductReview.css">

<div class="review-container container mt-5">

{{#statistic}}

<div class="rating-statistics">
    <div class="stat-item">
        <span>5점</span>
        <div class="bar-container">
            <div class="bar" style="width: {{statistic.fifthPercentage}}%"></div>
        </div>
        <span>{{statistic.fifthPercentage}}%</span>
    </div>
    <div class="stat-item">
        <span>4점</span>
        <div class="bar-container">
            <div class="bar" style="width: {{statistic.forthPercentage}}%"></div>
        </div>
        <span>{{statistic.forthPercentage}}%</span>
    </div>
    <div class="stat-item">
        <span>3점</span>
        <div class="bar-container">
            <div class="bar" style="width: {{statistic.thirdPercentage}}%"></div>
        </div>
        <span>{{statistic.thirdPercentage}}%</span>
    </div>
    <div class="stat-item">
        <span>2점</span>
        <div class="bar-container">
            <div class="bar" style="width: {{statistic.secondPercentage}}%"></div>
        </div>
        <span>{{statistic.secondPercentage}}%</span>
    </div>
    <div class="stat-item">
        <span>1점</span>
        <div class="bar-container">
            <div class="bar" style="width: {{statistic.firstPercentage}}%"></div>
        </div>
        <span>{{statistic.firstPercentage}}%</span>
    </div>
</div>
    </div>

{{/statistic}}

{{^statistic}}
    <div class="text-center py-5 border rounded bg-white">
        <i class="bi bi-chat-left-dots fs-1 text-muted"></i>
        <p class="mt-3 mb-0 text-muted">아직 작성된 리뷰가 없어 만족도 조사가 이루어지지 않았습니다.</p>
        <p class="fw-bold">이 상품을 가장 먼저 구매하고 리뷰를 남겨보세요!</p>
    </div>
{{/statistic}}

