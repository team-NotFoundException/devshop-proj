<div class="content-section">

    <div class="order-box">
        <div class="search-bar">
            <form action="/order/list">
                <div class="order-item">
                    <input type="text" name="keyword" value="{{#keyword}}{{keyword}}{{/keyword}}">
                    <button type="submit" class="search"><i class="fa-solid fa-magnifying-glass"></i></button>
                    <a class="reset" href="/order/list"><i class="fa-solid fa-arrows-rotate"></i></a>
                </div>
            </form>
        </div>

        {{#orderList}}
            <div class="order-card">
                <div class="order-header">
                    <h3 class="order-number">주문번호: {{orderNumber}}</h3>
                    <span class="order-date">주문일자: {{orderedAt}}</span>

                    <form action="/order/detail" style="margin: 0;">
                        <input type="hidden" name="orderId" value="{{id}}">
                        <button type="submit" class="detailBtn">상세보기</button>
                    </form>
                </div>

                {{#payments}}
                    <div class="order-item payment">
                        <img src="/images/{{thumbnailUrl}}"
                             alt="{{productName}}" class="product-image">
                        <div class="order-item-info">
                            <h4>{{productName}}</h4>
                            <p>개수: {{quantity}}</p>
                            <p>가격: {{orderAmount}}원</p>

                            <span class="status" data-status="{{status}}">{{statusDisplay}}</span>

                            <div class="order-item-buttons" id="order-item-buttons">
                                <button class="primary confirmBtn" type="button" data-payment-id="{{id}}">구매확정</button>
                                <button class=" refundBtn" type="button"
                                        data-payment-id="{{id}}"
                                        data-payment-method="{{method}}"
                                        data-payment-key="{{paymentKey}}"
                                        data-amount="{{orderAmount}}"
                                        data-order-id="{{orderId}}">반품신청
                                </button>
                                <a href="/review/{{productId}}/save" class="reviewBtn">리뷰 작성</a>
                            </div>
                        </div>
                    </div>
                {{/payments}}
            </div>
        {{/orderList}}
        {{^orderList}}
            <div class="order-card">
                <h3>주문내역이 없습니다.</h3>
            </div>
        {{/orderList}}
    </div>
</div>

<script>
    function updateOrderStatus(item) {
        const statusEl = item.querySelector('.status');
        const status = statusEl.dataset.status;

        if (status === 'SUCCESS') {
            item.querySelector('.status').textContent = '구매완료';
            item.querySelector('.confirmBtn').style.display = '';
            item.querySelector('.refundBtn').style.display = '';
            item.querySelector('.reviewBtn').style.display = 'none';
        }

        if (status === 'CONFIRMED') {
            item.querySelector('.status').textContent = '구매확정';
            item.querySelector('.confirmBtn').style.display = 'none';
            item.querySelector('.refundBtn').style.display = 'none';
            item.querySelector('.reviewBtn').style.display = '';
        }

        if (status === 'REFUNDED') {
            item.querySelector('.status').textContent = '환불';
            item.querySelector('.confirmBtn').style.display = 'none';
            item.querySelector('.refundBtn').style.display = 'none';
            item.querySelector('.reviewBtn').style.display = 'none';
        }
    }

    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll('.order-item-info').forEach(updateOrderStatus);

        document.querySelectorAll('.confirmBtn').forEach(btn => {
            btn.addEventListener('click', async function () {
                const item = this.closest('.order-item-info');
                const paymentId = this.dataset.paymentId;

                if (!confirm("구매확정 하시겠습니까?")) return;

                try {
                    let response = await fetch(`/payment/${paymentId}/confirm`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (response.ok) {
                        item.querySelector('.status').textContent = "구매확정";
                        item.querySelector('.confirmBtn').style.display = 'none';
                        item.querySelector('.refundBtn').style.display = 'none';
                        item.querySelector('.reviewBtn').style.display = '';
                    } else {
                        console.error(response);
                        alert("구매확정에 실패했습니다.");
                    }

                } catch (e) {
                    alert("오류가 발생했습니다." + e.message);
                }
            });
        });

        document.querySelectorAll('.refundBtn').forEach(btn => {
            btn.addEventListener('click', async function () {
                const item = this.closest('.order-item-info');
                const paymentId = this.dataset.paymentId;

                const reason = prompt("환불 사유를 입력해주세요:", "단순 변심");
                if (!reason) return;
                if (!confirm("반품하시겠습니까?")) return;

                try {
                    let response = await fetch(`/payment/${paymentId}/refund`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify( {
                            reason: reason,
                            amount: null
                        })
                    });

                    if (response.ok) {
                        const result = await response.json();
                        item.querySelector('.status').textContent = "환불";
                        item.querySelector('.confirmBtn').style.display = 'none';
                        item.querySelector('.refundBtn').style.display = 'none';
                        item.querySelector('.reviewBtn').style.display = 'none';

                        alert("환불이 완료되었습니다.");
                    } else {
                        const errorData = await response.json();
                        console.error(errorData);
                        alert("반품에 실패했습니다.");
                    }

                } catch (e) {
                    console.error("환불 오류:", e);
                    alert("오류가 발생했습니다." + e.message);
                }
            });
        });
    });

    document.querySelectorAll('.order-item-info').forEach(updateOrderStatus);
</script>