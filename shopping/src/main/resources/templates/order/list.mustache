<section class="mypage-content-box">
    <div class="card">
        {{#orderList}}
            <div class="order-card">
                <div class="order-header">
                    <h3>주문번호: {{orderId}}</h3>
                    <span>주문일: {{createdAt}}</span>
                    <form action="/order/detail">
                        <input type="hidden" name="id" value="{{orderId}}">
                        <button>상세보기</button>
                    </form>
                </div>

                {{#orderItemList}}
                    <div class="order-item">
                        <img src="" alt="{{productName}}" class="product-image">
                        <div class="order-item-info">
                            <h4>{{productName}}</h4>
                            <p>가격: {{productPrice}}원</p>
                            <p>수량: {{quantity}}개</p>
                            <span class="status" id="status">{{orderStatus}}</span>
                        </div>

                        {{#isComplete}}
                            <div class="order-item-buttons">
                                <button>리뷰작성</button>
                            </div>
                        {{/isComplete}}

                        {{^isComplete}}
                            <div class="order-item-buttons">
                                <button class="primary confirmBtn" data-order-item-id="{{id}}">구매확정</button>
                                <form action="/payment/{{id}}/refund" method="POST">
                                    <button class="refundBtn" type="submit">반품/교환신청</button>
                                </form>
                                <button>리뷰작성</button>
                            </div>
                        {{/isComplete}}

                    </div>
                {{/orderItemList}}
            </div>
        {{/orderList}}
        {{^orderList}}
            <div class="order-card">
                <h3>주문이 없습니다.</h3>
            </div>
        {{/orderList}}
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll('.confirmBtn').forEach(btn => {
            btn.addEventListener('click', function () {
                const orderItemId = this.dataset.orderItemId
                confirm("구매확정 하시겠습니까?")
                fetch(`/order/${orderItemId}/confirm`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                const statusContainer = this.closest('.order-item');
                statusContainer.querySelector('.status').textContent = "구매확정";
                const container = this.closest('.order-item-buttons');
                container.querySelector('.refundBtn').style.display = "none";
                btn.style.display = "none";
            });
        });
    });
</script>