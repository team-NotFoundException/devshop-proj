<section class="mypage-content-box">
    <div class="card">
        {{#orderList}}
            <div class="order-card">
                <div class="order-header">
                    <h3>주문번호: {{orderId}}</h3>
                    <span>주문일: {{createdAt}}</span>
                    <form action="/order/detail">
                        <input type="hidden" name="id" value="{{orderId}}">
                        <button>상세보기</button>
                    </form>
                </div>

                {{#orderItemList}}
                    <div class="order-item">
                        <img src="" alt="{{productName}}" class="product-image">
                        <div class="order-item-info">
                            <h4>{{productName}}</h4>
                            <p>가격: {{productPrice}}원</p>
                            <p>수량: {{quantity}}개</p>
                            <span class="status" id="status">{{orderStatus}}</span>
                        </div>
                        {{#isComplete}}
                            <div class="order-item-buttons">
                                <button>리뷰작성</button>
                            </div>
                        {{/isComplete}}
                        {{^isComplete}}
                            <div class="order-item-buttons">
                                <button class="primary" id="confirmBtn" onclick="confirmPurchase({{id}})">구매확정</button>
                                <button>반품/교환신청</button>
                                <button>리뷰작성</button>
                            </div>
                        {{/isComplete}}
                    </div>
                {{/orderItemList}}
            </div>
        {{/orderList}}
        {{^orderList}}
            <div class="order-card">
                <h3>주문이 없습니다.</h3>
            </div>
        {{/orderList}}
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        let orderStatus;

        const $confirmBtn = document.getElementById('confirmBtn');
        const $displayStatus = document.getElementById('status');

        function updateStatus(status) {
            orderStatus = status;
            $displayStatus.textContent = status.toLocaleString();
        }

        $confirmBtn.addEventListener('click', function () {
            fetch('/order/{orderItemId}/confirm', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({status: orderStatus})
            })
        })
    })
</script>