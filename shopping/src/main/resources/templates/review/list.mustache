<div class="mypage-content-box">
    <div class="card-header"><b>내가 쓴 리뷰 목록</b></div>

    {{#reviewList}}
        <div class="review-card">
            <div class="card-header product-title">상품: {{productName}}</div>

            <div class="card-body">
                <h4 class="card-title"><strong>내용:</strong> {{content}}</h4>
                <h4 class="card-title"><strong>작성자:</strong> {{username}}</h4>

                <div class="star-rating mb-2">
                    {{#stars}}
                        <span class="star filled">★</span>
                    {{/stars}}
                    {{#emptyStars}}
                        <span class="star">★</span>
                    {{/emptyStars}}
                </div>

                <span class="text-date">작성일: {{createdAt}}</span>
                <a href="/review/{{id}}" class="btn-review">상세보기</a>
            </div>
        </div>
    {{/reviewList}}

    {{^reviewList}}
        <div class="text-center py-5">
            <p class="text-muted">작성한 리뷰가 없습니다.</p>
        </div>
    {{/reviewList}}
</div>