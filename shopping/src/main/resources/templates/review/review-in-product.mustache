<link rel="stylesheet" href="/css/review/inProductReview.css">

<div class="review-container container mt-5">
    <div class="review-summary-box mb-4 p-4 border rounded shadow-sm bg-light">
        <h5 class="mb-3 fw-bold">상품 만족도 요약</h5>
        <div class="d-flex justify-content-between text-center">
            <div class="summary-item"><div class="label">매우 만족</div><div class="emoji">😍</div></div>
            <div class="summary-item"><div class="label">만족</div><div class="emoji">😊</div></div>
            <div class="summary-item"><div class="label">보통</div><div class="emoji">😐</div></div>
            <div class="summary-item"><div class="label">아쉬움</div><div class="emoji">😟</div></div>
            <div class="summary-item"><div class="label">매우 아쉬움</div><div class="emoji">😭</div></div>
        </div>
    </div>

    <div class="review-list-section">
        <ul class="list-unstyled">
            {{#inProductReviewList}}
                <li class="mb-3">
                    <div class="card border-0 shadow-sm p-3">
                        <div class="card-top d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold"><i class="bi bi-person-circle me-1"></i>{{username}}</span>
                            <span class="text-warning">
                                <span class="star-display" data-rating="{{rating}}">
                                    {{#rating}}★{{/rating}} ({{rating}}점)
                                </span>
                            </span>
                        </div>

                        <div class="card-body p-0 d-flex gap-3">
                            {{#reviewImage}}
                                <div class="review-img-wrapper" style="width: 100px; height: 100px;">
                                    <img src="{{reviewImage}}" class="img-fluid rounded object-fit-cover w-100 h-100" alt="리뷰 이미지">
                                </div>
                            {{/reviewImage}}

                            <div class="review-content flex-grow-1">
                                <p class="mb-0 text-secondary">{{content}}</p>
                            </div>
                        </div>
                    </div>
                </li>
            {{/inProductReviewList}}
        </ul>

        {{^inProductReviewList}}
            <div class="text-center py-5 border rounded bg-white">
                <i class="bi bi-chat-left-dots fs-1 text-muted"></i>
                <p class="mt-3 mb-0 text-muted">아직 작성된 리뷰가 없습니다.</p>
                <p class="fw-bold">이 상품을 가장 먼저 구매하고 리뷰를 남겨보세요!</p>
            </div>
        {{/inProductReviewList}}
    </div>
</div>