<div class="header-wrapper">
    <div class="container">
        {{> layout/header }}
    </div>
</div>

<link rel="stylesheet" href="/css/user/update-section.css">

<main class="mypage-main-wrapper">
    {{> layout/mypage-sidebar}}

    <div class="container p-5">
        <div class="card">
            <div class="card-header"><b>상품 리뷰 상세보기</b></div>

        <div class="text-center mb-4">
            {{#review.reviewImage}}
            {{!어 src 경로가 /images/ 이네... 스프링에 등록한 리소드 핸들러가 동작 함 }}
                <img src="/images/{{review.reviewImage}}" alt="리뷰 이미지" class="rounded-circle border"
                     style="width: 200px;height: 200px; object-fit: cover">
            {{/review.reviewImage}}

            {{^review.reviewImage}}
                <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center border"
                     style="width: 200px; height: 200px;">
                    <span class="text-white fs-5">리뷰 사진 없음</span>
                </div>
            </div>
            {{/review.reviewImage}}
        </div>

        <div class="mb-3">
            <div class="form-control">내용: {{review.content}}</div>
        </div>
        <div class="mb-3">
            <div class="form-control">별점: {{review.rating}}</div>
        </div>
        <div class="mb-3">
            <div class="form-control">작성자: {{review.username}}</div>
        </div>
        <!-- 수정삭제버튼 -->
        {{#isOwner}}
            <div class="d-flex justify-content-end mb-2">
                <a href="/review/{{id}}/update" class="btn btn-warning me-2">수정</a>
                <form action="/review/{{id}}/delete" method="post">
                    <button class="btn btn-danger">삭제</button>
                </form>
            </div>
        {{/isOwner}}
    </div>
</main>

{{> layout/footer }}