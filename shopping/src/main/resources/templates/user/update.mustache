{{> layout/header }}

<div class="container mt-5">
    <main class="mypage-main-wrapper d-flex gap-4">
        {{> layout/mypage-sidebar}}
        <section class="mypage-content-box flex-grow-1">
            <h1 class="mb-4 fw-bold">내 정보 수정</h1>

            <form action="/user/update" method="post" class="update-form">

                <div class="update-form-group mb-3">
                    <label for="password" class="form-label fw-bold">
                        비밀번호 <span class="text-danger">*</span>
                    </label>
                    <input type="password" id="password" name="password"
                           class="form-control"
                           value="{{sessionUser.password}}"
                           placeholder="6자 이상 16자 이하의 비밀번호를 입력하세요" required>
                </div>

                <div class="update-form-group mb-3">
                    <label for="nickname" class="form-label fw-bold">
                        닉네임 <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="nickname" name="nickname"
                           class="form-control"
                           value="{{sessionUser.nickname}}" required>
                </div>

                <div class="update-form-group mb-3">
                    <label for="address" class="form-label fw-bold">
                        주소 <span class="text-danger">*</span>
                    </label>
                    <div class="address-container p-3 border rounded bg-light">
                        {{> user/address-form }}
                    </div>
                </div>

                <div class="update-form-group mb-4">
                    <label class="form-label fw-bold">성별</label>
                    <div class="gender-radio-group d-flex gap-4 mt-2">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="gender" id="genderM" value="M" {{#isMale}}checked{{/isMale}}>
                            <label class="form-check-label" for="genderM">남성</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="gender" id="genderF" value="F" {{#isFemale}}checked{{/isFemale}}>
                            <label class="form-check-label" for="genderF">여성</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="gender" id="genderN" value="N" {{#isNone}}checked{{/isNone}}>
                            <label class="form-check-label" for="genderN">선택 안 함</label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-dark w-100 py-3 fw-bold">수정하기</button>
            </form>
        </section>
    </main>
</div>

{{> layout/footer}}