{{> layout/header}}

<div class="d-flex">
    {{> layout/owner-sidebar}}

    <main class="flex-grow-1 p-5 bg-light">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold">운영 현황</h2>
                <a href="/products/save" class="btn btn-primary">+ 새 상품 등록</a>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 p-3">
                        <div class="card-body">
                            <h6 class="text-muted">전체 상품</h6>
                            <h3 class="fw-bold mb-0">{{totalCount}}</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 p-3 text-white bg-success">
                        <div class="card-body">
                            <h6 class="text-white-50">판매 중</h6>
                            <h3 class="fw-bold mb-0">{{activeCount}}</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 p-3 text-white bg-secondary">
                        <div class="card-body">
                            <h6 class="text-white-50">품절 상품</h6>
                            <h3 class="fw-bold mb-0">{{soldOutCount}}</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">최근 등록 상품</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                        <tr>
                            [cite_start]<th>상품명 [cite: 2]</th>
                            [cite_start]<th>가격 [cite: 2]</th>
                            [cite_start]<th>재고 [cite: 2]</th>
                            [cite_start]<th>상태 [cite: 2]</th>
                            <th>관리</th>
                        </tr>
                        </thead>
                        <tbody>
                        {{#recentProducts}}
                            <tr>
                                <td><a href="/products/{{id}}/detail" class="text-decoration-none fw-bold text-dark">{{productName}}</a></td>
                                [cite_start]<td>{{price}}원 [cite: 3]</td>
                                [cite_start]<td>{{stockQuantity}}개 [cite: 3]</td>
                                [cite_start]<td><span class="badge bg-light text-dark border">{{status}}</span> [cite: 3]</td>
                                <td>
                                    <a href="/products/{{id}}/edit" class="btn btn-sm btn-outline-warning">수정</a>
                                </td>
                            </tr>
                        {{/recentProducts}}
                        {{^recentProducts}}
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">등록된 상품이 없습니다.</td>
                            </tr>
                        {{/recentProducts}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>

{{> layout/footer}}