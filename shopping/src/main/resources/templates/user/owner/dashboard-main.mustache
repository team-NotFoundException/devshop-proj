<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">운영 현황</h3>
        <a href="/owner/products/save" class="btn btn-dark btn-sm">
            <i class="bi bi-plus-lg"></i> 상품 등록
        </a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stat-card bg-primary-dark">
                <h5>전체 상품</h5>
                <div class="value">{{totalCount}} 개</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-success-dark">
                <h5>판매 중인 상품</h5>
                <div class="value">{{activeCount}} 개</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-warning-dark">
                <h5>품절된 상품</h5>
                <div class="value">{{soldOutCount}} 개</div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <h4 class="mb-3">최근 등록 상품</h4>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                <tr>
                    <th>상품명</th>
                    <th>가격</th>
                    <th>재고</th>
                    <th>상태</th>
                    <th class="text-center">관리</th>
                </tr>
                </thead>
                <tbody>
                {{#recentProducts}}
                    <tr>
                        <td class="fw-semibold">
                            <a href="/owner/products/{{id}}" class="text-decoration-none text-dark">
                                {{productName}}
                            </a>
                        </td>
                        <td>{{price}}원</td>
                        <td>{{stockQuantity}}개</td>
                        <td>
                            {{#active}}
                                <span class="badge bg-success-subtle text-success border border-success">판매중</span>
                            {{/active}}
                            {{#soldOut}}
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary">품절</span>
                            {{/soldOut}}
                        </td>
                        <td class="text-center">
                            <a href="/owner/products/{{id}}/edit" class="btn btn-sm btn-outline-warning">수정</a>
                        </td>
                    </tr>
                {{/recentProducts}}
                {{^recentProducts}}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            아직 등록된 상품이 없습니다.
                        </td>
                    </tr>
                {{/recentProducts}}
                </tbody>
            </table>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-3">
                <h5 class="card-title text-center mb-3">판매 내역 조회</h5>
                <canvas id="Chart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById("Chart");

</script>
