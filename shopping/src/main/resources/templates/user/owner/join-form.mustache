<div class="header-wrapper">
    <div class="container">
        {{> layout/header }}
    </div>
</div>

<div class="join-container">
    <div class="register-box">
        <h2 class="title">입점자 회원가입</h2>

        <div class="d-flex justify-content-space-between">
            <h5>일반 회원가입 --></h5>
            <a href="/user/join"><i class="fas fa-user"></i></a>
        </div>

        <form action="/owner/join" method="post" onsubmit="return handleFormSubmit()">

            <!-- 아이디 -->
            <div class="join-form-group">
                <label for="username">아이디 <span class="required">*</span></label>
                <div class="custom-input-group">
                    <input type="text" id="username" name="username" placeholder="5자~12자 이내" required>
                    <button type="button" class="btn-sub-action" onclick="usernameCheck()">중복확인</button>
                </div>
                <small id="usernameMsg"></small>
            </div>

            <!-- 비밀번호 -->
            <div class="join-form-group">
                <label for="password">비밀번호 <span class="required">*</span></label>
                <input type="password"
                       id="password"
                       name="password"
                       placeholder="6자~16자 이내"
                       required>
                <small>6~16자, 영문/숫자/특수문자 중 2가지 이상 조합</small>
            </div>

            <div class="join-form-group">
                <label for="nickname">닉네임 <span class="required">*</span></label>
                <input type="text" id="nickname" name="nickname" placeholder="2자 이상 6자 이하">
            </div>

            <!-- 입점사명 (Owner 전용) -->
            <div class="join-form-group">
                <label for="ownerName">입점사명 <span class="required">*</span></label>
                <input type="text"
                       id="ownerName"
                       name="ownerName"
                       placeholder="입점사 이름을 입력하세요"
                       required>
            </div>

            <!-- 이메일 -->
            <div class="join-form-group">
                <label for="email">이메일 주소 <span class="required">*</span></label>
                <input type="text"
                       id="email"
                       name="email"
                       placeholder="예) sample@dev.com"
                       required>
            </div>

            <!-- 주소 -->
            <div class="join-form-group">
                <label>주소 <span class="required">*</span></label>
                <div class="custom-input-group address-group">
                    {{> user/address-form}}
                </div>
            </div>

            <!-- 연락처 -->
            <div class="join-form-group">
                <label for="phoneNumber">대표자 연락처 <span class="required">*</span></label>
                <input type="text"
                       id="phoneNumber"
                       name="phoneNumber"
                       placeholder="010-xxxx-xxxx"
                       required>
            </div>

            <!-- 성별 -->
            <div class="join-form-group">
                <label>성별</label>
                <div class="gender-group">
                    <label class="gender-card">
                        <input type="radio" name="gender" value="M">
                        <span class="gender-text">남성</span>
                    </label>
                    <label class="gender-card">
                        <input type="radio" name="gender" value="F">
                        <span class="gender-text">여성</span>
                    </label>
                    <label class="gender-card">
                        <input type="radio" name="gender" value="N" checked>
                        <span class="gender-text">선택 안 함</span>
                    </label>
                </div>
            </div>

            <!-- 사업자 등록일 -->
            <div class="join-form-group">
                <label for="birthday">사업자 등록일</label>
                <input type="date"
                       id="birthday"
                       name="birthday">
            </div>

            <button type="submit" class="btn-register-main">
                입점 신청하기
            </button>
        </form>
    </div>
</div>

{{> layout/footer }}

<script src="/js/join-common.js"></script>