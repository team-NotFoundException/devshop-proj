{{> layout/header}}

<div class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <div class="content-section">
        <h2 class="mb-4">회원 관리</h2>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>아이디</th>
                    <th>닉네임</th>
                    <th>권한</th>
                    <th>가입일</th>
                    <th>관리</th>
                </tr>
                </thead>
                <tbody>
                {{#userList}}
                    <tr>
                        <td>{{id}}</td>
                        <td>{{username}}</td>
                        <td>{{nickname}}</td>
                        <td><span class="badge bg-info">{{role}}</span></td>
                        <td>{{createdAt}}</td>
                        <td>
                            <div class="d-flex gap-2">
                                <form action="/admin/user/{{id}}/delete" method="post" onsubmit="return confirm('정말 삭제하시겠습니까?');">
                                    <button class="btn btn-danger btn-sm">삭제</button>
                                </form>
                                <a href="/admin/users/{{id}}/edit" class="btn btn-warning btn-sm">수정</a>
                            </div>
                        </td>
                    </tr>
                {{/userList}}
                </tbody>
            </table>
        </div>
    </div>
</div>

{{> layout/footer}}