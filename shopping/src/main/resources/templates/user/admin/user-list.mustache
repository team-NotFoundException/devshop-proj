<div class="header-wrapper">
    <div class="container">
        {{> layout/header }}
    </div>
</div>
<link rel="stylesheet" href="/css/admin-owner/style.css">

<main class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <section class="content-section">
        <h2>회원 관리</h2>
        <table class="data-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>아이디</th>
                <th>닉네임</th>
                <th>권한</th>
                <th>가입일</th>
                <th>관리</th>
            </tr>
            </thead>
            <tbody>
            {{#userList}}
                <tr>
                    <td>{{id}}</td>
                    <td>{{username}}</td>
                    <td>{{nickname}}</td>
                    <td><span class="badge bg-info">{{role}}</span></td>
                    <td>{{createdAt}}</td>
                    <td>
                        <a href="/admin/users/{{id}}/edit" class="btn-sm btn-edit">수정</a>
                    </td>
                </tr>
            {{/userList}}
            </tbody>
        </table>
    </section>
</main>
{{> layout/footer}}

