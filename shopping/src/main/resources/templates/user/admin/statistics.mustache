{{> layout/header}}

<div class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <div class="content-section">
        <h2 class="mb-4">매출 및 결제 통계</h2>

        <div class="table-responsive mb-5">
            <table class="data-table">
                <thead>
                <tr>
                    <th>이름</th>
                    <th>제품명</th>
                    <th>결제 금액</th>
                    <th>결제 방법</th>
                    <th>상태</th>
                    <th>생성 시간</th>
                </tr>
                </thead>
                <tbody>
                {{#historyList}}
                    <tr>
                        <td>{{username}}</td>
                        <td>{{productName}}</td>
                        <td>{{amount}}</td>
                        <td>{{method}}</td>
                        <td><span class="badge bg-primary">{{newValue}}</span></td>
                        <td>{{createdAt}}</td>
                    </tr>
                {{/historyList}}
                </tbody>
            </table>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm p-3">
                    <h5 class="card-title text-center mb-3">결제 상태별 분포</h5>
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm p-3">
                    <h5 class="card-title text-center mb-3">결제 수단별 비중</h5>
                    <canvas id="methodChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('statusChart');
    const ctxM = document.getElementById('methodChart');
    const historyData = [];

        {{#historyList}}
        historyData.push({
            newValue: "{{newValue}}",
            method: "{{method}}"
        })
        {{/historyList}}

    console.log(historyData)

    const statusCount = {};
    const methodCount = {};
    historyData.forEach(item => {
        if (statusCount[item.newValue]) {
            statusCount[item.newValue]++;
        } else {
            statusCount[item.newValue] = 1;
        }

        if (methodCount[item.method]) {
            methodCount[item.method]++;
        } else {
            methodCount[item.method] = 1;
        }
    });

    console.log(statusCount)

    const statusLabels = Object.keys(statusCount);
    const statusData = Object.values(statusCount);
    const methodLabels = Object.keys(methodCount);
    const methodData = Object.values(methodCount);

    console.log(statusData)

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: statusLabels,
            datasets: [{
                label: statusLabels,
                data: statusData,
                backgroundColor: [
                    'rgba(75, 192, 192, 0.8)',   // 청록색
                    'rgba(255, 99, 132, 0.8)',   // 빨간색
                    'rgba(255, 206, 86, 0.8)',   // 노란색
                    'rgba(54, 162, 235, 0.8)',   // 파란색
                    'rgba(153, 102, 255, 0.8)',  // 보라색
                    'rgba(255, 159, 64, 0.8)'    // 주황색
                ],
                borderColor: [
                    'rgba(75, 192, 192, 1)',
                    'rgba(255, 99, 132, 1)',
                    'rgba(255, 206, 86, 1)',
                    'rgba(54, 162, 235, 1)',
                    'rgba(153, 102, 255, 1)',
                    'rgba(255, 159, 64, 1)'
                ], borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'top',
                },
                title: {
                    display: true,
                    text: '결제 상태별 분포'
                }
            }
        }
    });
    new Chart(ctxM, {
        type: 'pie',
        data: {
            labels: methodLabels,
            datasets: [{
                label: "methodLabels",
                data: methodData,
                backgroundColor: [
                    'rgba(75, 192, 192, 0.8)',   // 청록색
                    'rgba(255, 99, 132, 0.8)',   // 빨간색
                    'rgba(255, 206, 86, 0.8)',   // 노란색
                    'rgba(54, 162, 235, 0.8)',   // 파란색
                    'rgba(153, 102, 255, 0.8)',  // 보라색
                    'rgba(255, 159, 64, 0.8)'    // 주황색
                ],
                borderColor: [
                    'rgba(75, 192, 192, 1)',
                    'rgba(255, 99, 132, 1)',
                    'rgba(255, 206, 86, 1)',
                    'rgba(54, 162, 235, 1)',
                    'rgba(153, 102, 255, 1)',
                    'rgba(255, 159, 64, 1)'
                ], borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'top',
                },
                title: {
                    display: true,
                    text: '결제 방법 분포'
                }
            }
        }
    });
</script>