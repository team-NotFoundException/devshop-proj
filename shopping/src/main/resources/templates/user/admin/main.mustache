{{> layout/header}}

<div class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <div class="content-section">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>대시보드</h2>
        </div>

        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="stat-card bg-primary-dark">
                    <h5>오늘 방문자</h5>
                    <div class="value">1,250 명</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card bg-success-dark">
                    <h5>오늘 매출액</h5>
                    <div class="value">₩ 3,450,000</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card bg-warning-dark">
                    <h5>신규 가입</h5>
                    <div class="value">12 명</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card bg-info-dark">
                    <h5>문의 사항</h5>
                    <div class="value">5 건</div>
                </div>
            </div>
        </div>

        <div class="mt-5">
            <h4 class="mb-3">최근 가입 회원</h4>
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                    <tr>
                        <th>번호</th>
                        <th>아이디</th>
                        <th>닉네임</th>
                        <th>권한</th>
                        <th>가입일</th>
                        <th>상태</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#recentUsers}}
                        <tr>
                            <td>{{id}}</td>
                            <td>{{username}}</td>
                            <td>{{nickname}}</td>
                            <td><span class="badge bg-secondary">{{role}}</span></td>
                            <td>{{createdAt}}</td>
                            <td><span class="text-success">정상</span></td>
                        </tr>
                    {{/recentUsers}}
                    {{^recentUsers}}
                        <tr>
                            <td colspan="6" class="text-center">데이터가 없습니다.</td>
                        </tr>
                    {{/recentUsers}}
                    </tbody>
                </table>
            </div>
            <div class="text-end mt-2">
                <a href="/admin/list" class="btn btn-link p-0 text-decoration-none">전체 회원 보기 ></a>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}