{{> layout/header}}


<div class="admin-container">
    {{> layout/admin-sidebar}}

    <main class="flex-grow-1 p-4 bg-light">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>대시보드</h2>
            <button class="btn btn-outline-primary btn-sm">보고서 다운로드</button>
        </div>

        <div class="row">
            <div class="col-md-3">
                <div class="stat-card bg-primary-dark">
                    <h5>오늘 방문자</h5>
                    <div class="value">1,250 명</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card bg-success-dark">
                    <h5>오늘 매출액</h5>
                    <div class="value">₩ 3,450,000</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card bg-warning-dark">
                    <h5>신규 가입</h5>
                    <div class="value">12 명</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card bg-info-dark">
                    <h5>미답변 문의</h5>
                    <div class="value">5 건</div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-lg-12">
                <div class="admin-table-container">
                    <h5 class="mb-3">최근 가입 회원 현황</h5>
                    <table class="table table-hover">
                        <thead class="table-light">
                        <tr>
                            <th>번호</th>
                            <th>아이디</th>
                            <th>닉네임</th>
                            <th>권한</th>
                            <th>가입일</th>
                            <th>상태</th>
                        </tr>
                        </thead>
                        <tbody>
                        {{#recentUsers}}
                            <tr>
                                <td>{{id}}</td>
                                <td>{{username}}</td>
                                <td>{{nickname}}</td>
                                <td><span class="badge bg-secondary">{{role}}</span></td>
                                <td>{{createdAt}}</td>
                                <td><span class="text-success">정상</span></td>
                            </tr>
                        {{/recentUsers}}
                        {{^recentUsers}}
                            <tr>
                                <td colspan="6" class="text-center">데이터가 없습니다.</td>
                            </tr>
                        {{/recentUsers}}
                        </tbody>
                    </table>
                    <div class="text-end">
                        <a href="/admin/list" class="btn btn-link">전체 회원 보기 ></a>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

{{> layout/footer}}