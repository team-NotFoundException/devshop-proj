{{> layout/header }}

<div class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <div class="content-section">
        {{#product}}
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 fw-bold">{{productName}} <small class="text-muted fs-6">#{{id}}</small></h4>
                </div>

                <div class="card-body p-4">
                    {{#thumbnailUrl}}
                        <div class="product-thumbnail-section mb-4 text-center">
                            <img src="{{thumbnailUrl}}" alt="{{productName}}"
                                 class="img-fluid rounded shadow-sm"
                                 style="max-width: 400px; max-height: 400px; object-fit: cover;">
                        </div>
                    {{/thumbnailUrl}}

                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">판매자</div>
                                <div class="h5 fw-bold">{{ownerName}}</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">카테고리</div>
                                <div class="h5 fw-bold">{{categoryName}}</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">가격</div>
                                <div class="h4 fw-bold text-primary">{{price}}원</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">재고</div>
                                <div class="h4 fw-bold text-success">{{stockQuantity}}개</div>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3 border-bottom pb-2">상세 설명</h5>
                    <div class="product-detail-content mb-5">
                        {{{description}}}
                    </div>

                    <div class="d-flex justify-content-between border-top pt-4">
                        <a href="/admin/products" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> 목록으로
                        </a>
                    </div>
                </div>
            </div>
        {{/product}}
    </div>
</div>

{{> layout/footer }}