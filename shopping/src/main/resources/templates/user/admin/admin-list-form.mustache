<div class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <div class="content-section">
        <h2 class="mb-4">전체 상품 관리</h2>

        <div class="mb-4">
            <form action="/admin/products/search" method="get" class="d-flex gap-2" style="max-width: 500px;">
                <input type="text" name="keyword" class="form-control" placeholder="상품명으로 검색..." value="{{keyword}}">
                <button type="submit" class="btn btn-dark text-nowrap">검색</button>
            </form>
        </div>

        {{#keyword}}
            <div class="alert alert-light d-flex justify-content-between align-items-center border mb-4">
                <span>"<strong>{{keyword}}</strong>" 검색 결과</span>
                <a href="/admin/products" class="btn btn-sm btn-outline-secondary">목록 초기화</a>
            </div>
        {{/keyword}}

        <div class="table-responsive">
            <table class="data-table">
                <thead>
                <tr>
                    <th width="80">ID</th>
                    <th>상품명</th>
                    <th>가격</th>
                    <th>재고</th>
                    <th>상태</th>
                </tr>
                </thead>
                <tbody>
                {{#products}}
                    <tr>
                        <td>{{id}}</td>
                        <td><a href="/admin/products/{{id}}" class="text-primary fw-bold text-decoration-none">{{productName}}</a></td>
                        <td>{{price}}원</td>
                        <td>{{stockQuantity}}</td>
                        <td><span class="badge bg-secondary">{{status}}</span></td>
                    </tr>
                {{/products}}
                {{^products}}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">등록된 상품이 없습니다.</td>
                    </tr>
                {{/products}}
                </tbody>
            </table>
        </div>
    </div>
</div>