
    <div class="container-fluid">

        <!-- 검색 폼 -->
        <div class="search-container">
            <form action="/admin/products/search" method="get" class="search-form" onsubmit="return validateSearch()">
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text"
                           name="keyword"
                           class="search-input"
                           placeholder="상품명으로 검색하세요..."
                           value="{{keyword}}"
                           required>
                    <button type="submit" class="search-btn">검색</button>
                </div>
            </form>
        </div>

        <!-- 검색 결과 표시 -->
        {{#keyword}}
            <div class="search-result-info">
                <div class="result-text">
                    <i class="bi bi-search"></i>
                    <span>"<strong>{{keyword}}</strong>" 검색 결과</span>
                </div>
                <a href="/admin/products" class="btn-reset">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    전체 목록
                </a>
            </div>
        {{/keyword}}



        <!-- 상품 테이블 -->
        <div class="table-container">
            <table class="product-table">
                <thead>
                <tr>
                    <th width="80">ID</th>
                    <th>상품명</th>
                    <th width="150">가격</th>
                    <th width="100">재고</th>
                    <th width="120">상태</th>
                </tr>
                </thead>
                <tbody>
                {{#products}}
                    <tr class="product-row">
                        <td class="id-cell">{{id}}</td>
                        <td class="name-cell">
                            <a href="/admin/products/{{id}}" class="product-link">{{productName}}</a>
                        </td>
                        <td class="price-cell">{{price}}원</td>
                        <td class="stock-cell">{{stockQuantity}}</td>
                        <td class="status-cell">
                            <span class="status-badge status-{{status}}">{{status}}</span>
                        </td>
                    </tr>
                {{/products}}
                {{^products}}
                    <tr>
                        <td colspan="5" class="empty-cell">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <p>
                                    {{#keyword}}
                                        검색 결과가 없습니다.
                                    {{/keyword}}
                                    {{^keyword}}
                                        등록된 상품이 없습니다.
                                    {{/keyword}}
                                </p>
                            </div>
                        </td>
                    </tr>
                {{/products}}
                </tbody>
            </table>
        </div>
    </div>

