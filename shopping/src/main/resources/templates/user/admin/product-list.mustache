{{> layout/header }}

<div class="admin-owner-wrapper">
    {{> layout/admin-sidebar}}

    <div class="content-section">


        <div class="page-header">
            <h2>전체 상품 관리</h2>
            <a href="/owner/products/save" class="btn-add">
                <i class="bi bi-plus-lg"></i> 상품 등록
            </a>
        </div>


        <div class="search-container">
            <form action="/admin/products/search" method="get">
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text"
                           name="keyword"
                           class="search-input"
                           placeholder="상품명으로 검색하세요"
                           value="{{keyword}}">
                    <button type="submit" class="search-btn">검색</button>
                </div>
            </form>
        </div>


        {{#keyword}}
            <div class="search-result-info">
                <div class="result-text">
                    <i class="bi bi-search"></i>
                    "<strong>{{keyword}}</strong>" 검색 결과
                </div>
                <a href="/admin/products" class="btn-reset">
                    <i class="bi bi-arrow-clockwise"></i> 전체 목록
                </a>
            </div>
        {{/keyword}}


        <div class="table-container">
            <table class="product-table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>상품명</th>
                    <th>가격</th>
                    <th>재고</th>
                    <th style="text-align:center;">상태</th>
                </tr>
                </thead>
                <tbody>

                {{#products}}
                    <tr>
                        <td class="id-cell">{{id}}</td>
                        <td>
                            <a href="/admin/products/{{id}}" class="product-link">
                                {{productName}}
                            </a>
                        </td>
                        <td class="price-cell">{{price}}원</td>
                        <td class="stock-cell">{{stockQuantity}}</td>
                        <td class="status-cell">
                        <span class="status-badge status-{{status}}">
                            {{status}}
                        </span>
                        </td>
                    </tr>
                {{/products}}

                {{^products}}
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <p>등록된 상품이 없습니다.</p>
                            </div>
                        </td>
                    </tr>
                {{/products}}

                </tbody>
            </table>
        </div>

    </div>
</div>

{{> layout/footer }}
