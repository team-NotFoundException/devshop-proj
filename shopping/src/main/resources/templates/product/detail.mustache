{{> layout/header}}

<div class="container p-5">
    {{#product}}
        <div class="card mb-3">
            <div class="card-body">
                <h4 class="card-title mb-3">{{productName}}</h4>
                <div>가격: {{price}}</div>
                <div>상태: {{status}}</div>

                <a href="/products/{{id}}/edit" class="btn btn-warning">
                    상세정보
                </a>
            </div>
        </div>
    {{/product}}
</div>

{{> layout/footer}}