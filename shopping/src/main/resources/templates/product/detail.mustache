{{> layout/header}}

<div class="container p-5">
    {{#product}}
        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <h4 class="card-title mb-3">{{productName}}</h4>

                <div class="mb-2">
                    <strong>가격:</strong> {{price}}
                </div>

                <div class="mb-3">
                    <strong>상태:</strong>
                    <span class="badge bg-secondary">{{status}}</span>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/products/list-form" class="btn btn-outline-secondary">
                        목록으로
                    </a>

                    <a href="/products/{{id}}/edit" class="btn btn-warning">
                        수정
                    </a>
                </div>

            </div>
        </div>
    {{/product}}
</div>

{{> layout/footer}}