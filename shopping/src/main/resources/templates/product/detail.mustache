{{> layout/header }}

<!-- 사이드바 + 컨텐츠 Flex 컨테이너 -->
<div class="dashboard-wrapper" style="display: flex; min-height: 100vh; gap: 20px;">

    <!-- 사이드바 -->
    {{> layout/owner-sidebar}}

    <!-- 컨텐츠 영역 -->
    <div class="content-area" style="flex: 1; padding: 20px;">

        {{#product}}
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 fw-bold">{{productName}} <small class="text-muted fs-6">#{{id}}</small></h4>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">판매 가격</div>
                                <div class="h4 fw-bold text-primary">{{price}}원</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">판매 상태</div>
                                <span class="badge bg-secondary">{{status}}</span>
                            </div>
                        </div>
                    </div>


                    <h5 class="fw-bold mb-3 border-bottom pb-2">상세 설명</h5>
                    <div class="product-detail-content mb-5">
                        {{{description}}}
                    </div>

                    <div class="d-flex justify-content-between border-top pt-4">
                        <a href="/owner/products" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> 목록으로
                        </a>
                        <a href="/owner/products/{{id}}/edit" class="btn btn-warning px-4 fw-bold">
                            정보 수정하기
                        </a>
                    </div>
                </div>
            </div>
        {{/product}}

    </div>
</div>

{{> layout/footer }}