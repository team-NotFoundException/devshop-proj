{{> layout/header}}

<div class="admin-owner-wrapper">
    {{> layout/owner-sidebar}}

    <div class="content-section">

        {{#product}}
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 fw-bold">{{productName}} <small class="text-muted fs-6"></small></h4>
                </div>

                <div class="card-body p-4">
                    <!-- 썸네일 이미지 섹션 -->
                    {{#thumbnailUrl}}
                        <div class="product-thumbnail-section mb-4 text-center">
                            <img src="{{thumbnailUrl}}" alt="{{productName}}"
                                 class="img-fluid rounded shadow-sm"
                                 style="max-width: 400px; max-height: 400px; object-fit: cover;">
                        </div>
                    {{/thumbnailUrl}}

                    <!-- 상품 정보 카드 -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">판매 가격</div>
                                <div class="h4 fw-bold text-primary">{{price}}원</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">재고 수량</div>
                                <div class="h4 fw-bold text-success">{{stockQuantity}}개</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded text-center">
                                <div class="text-muted small">판매 상태</div>
                                <span class="badge bg-secondary fs-6">{{status}}</span>
                            </div>
                        </div>
                    </div>

                    <!-- 상세 설명 -->
                    <h5 class="fw-bold mb-3 border-bottom pb-2">상세 설명</h5>
                    <div class="product-detail-content mb-5">
                        {{{description}}}
                    </div>

                    <!-- 하단 버튼 -->
                    <div class="d-flex justify-content-between border-top pt-4">
                        <a href="/owner/products" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> 목록으로
                        </a>
                        <a href="/owner/products/{{id}}/edit" class="btn btn-warning px-4 fw-bold">
                            정보 수정하기
                        </a>
                    </div>
                </div>
            </div>
        {{/product}}

    </div>
</div>

{{> layout/footer }}