{{> layout/header }}

{{#product}}
    <div class="product-detail-container">

        <!-- 상단 영역: 이미지 갤러리 + 구매 정보 -->
        <div class="top-area">



                <!-- 큰 메인 이미지 -->
                <div class="main-image-area">
                    {{#thumbnailUrl}}
                        <img src="/images/{{thumbnailUrl}}" alt="{{name}}">
                    {{/thumbnailUrl}}
                </div>
            </div>

            <!-- 오른쪽: 간단한 구매 정보 -->
            <div class="purchase-summary">
                <h1 class="product-name">{{name}}</h1>
                <div class="product-price">{{price}}원</div>
                <button class="buy-button">구매하기</button>
            </div>
        </div>

        <!-- 중간 영역: 상품 설명 이미지들 -->
        <div class="product-description">
            {{{description}}}
        </div>

        <!-- 하단 영역: 에디터 (결제 시스템) -->
        <div class="purchase-area">
            <h2>구매 옵션</h2>
            <!-- 결제 시스템 들어갈 자리 -->
        </div>

    </div>
{{/product}}

<style>
    .product-detail-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }

    /* 상단 2컬럼 레이아웃 */
    .top-area {
        display: flex;
        gap: 40px;
        margin-bottom: 60px;
    }

    /* 왼쪽 이미지 섹션 */
    .product-image-section {
        display: flex;
        gap: 20px;
        flex: 1;
        max-width: 600px;
    }

    /* 작은 썸네일 리스트 */
    .thumbnail-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .thumbnail-item {
        width: 80px;
        height: 80px;
        object-fit: cover;
        cursor: pointer;
        border: 2px solid transparent;
        border-radius: 8px;
    }

    .thumbnail-item.active {
        border-color: #222;
    }

    /* 큰 메인 이미지 */
    .main-image-area {
        flex: 1;
    }

    .main-image-area img {
        width: 100%;
        height: auto;
        border-radius: 12px;
        object-fit: cover;
    }

    /* 오른쪽 간단한 구매 정보 */
    .purchase-summary {
        width: 360px;
        flex-shrink: 0;
        position: sticky;
        top: 20px;
        align-self: flex-start;
    }

    .product-name {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .product-price {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 24px;
    }

    .buy-button {
        width: 100%;
        padding: 16px;
        background-color: #000;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
    }

    .buy-button:hover {
        background-color: #333;
    }

    /* 상품 설명 */
    .product-description {
        margin-bottom: 60px;
        line-height: 1.7;
    }

    .product-description img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 20px 0;
    }

    /* 하단 에디터 영역 */
    .purchase-area {
        background-color: #f9f9f9;
        padding: 40px;
        border-radius: 12px;
        margin-bottom: 60px;
    }

    .purchase-area h2 {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 24px;
    }

    /* 반응형 */
    @media (max-width: 968px) {
        .top-area {
            flex-direction: column;
        }

        .purchase-summary {
            width: 100%;
            position: static;
        }
    }
</style>

{{> layout/footer }}