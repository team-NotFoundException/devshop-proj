{{> layout/header }}

<link rel="stylesheet" href="/css/product/user-detail.css">

<div class="product-detail-container">
    {{#product}}
        <div class="detail-main-content">
            <div class="content-left">
                <div class="main-image-area">
                    {{#thumbnailUrl}}
                        <img src="/images/{{thumbnailUrl}}" alt="{{name}}">
                    {{/thumbnailUrl}}
                </div>

                <nav class="product-tab-nav">
                    <ul>
                        <li class="active" onclick="loadTab('description', this)">상세정보</li>
                        <li onclick="loadTab('review', this, {{id}})">리뷰</li>
                    </ul>
                </nav>

                <div id="tab-content" class="tab-content-area">
                    <section class="product-description">
                        {{{description}}}
                    </section>
                </div>
            </div>

            <aside class="purchase-sidebar">
                <div class="sticky-box">
                    <h1 class="product-name">{{name}}</h1>
                    <div class="price-info">
                        <span class="discount-rate"></span>
                        <span class="current-price">{{price}}원</span>
                    </div>

                    <div class="option-selector">
                        <p class="option-title">수량선택</p>
                        <div class="quantity-control">
                            <button type="button" onclick="changeQty(-1)"><i
                                    class="fa-solid fa-minus"></i></button>
                            <input type="number" id="quantity" readonly value="1">
                            <button type="button" onclick="changeQty(1)"><i
                                    class="fa-solid fa-plus"></i></button>
                        </div>
                    </div>

                    <div class="total-summary">
                        <div class="summary-line">
                            <p>총 수량 <strong id="total-qty">1</strong>개</p>
                            <p>총 주문금액 <strong id="total-price" class="text-danger" data-price="{{price}}">{{price}}</strong>원</p>
                        </div>
                    </div>

                    <div class="action-buttons">
                        <button class="cart-btn" data-product-id="{{id}}">장바구니 담기</button>
                        <button class="buy-now-btn">바로구매</button>
                    </div>
                </div>
            </aside>
        </div>

        <script id="origin-description" type="text/template">
            <section class="product-description">{{{description}}}</section>
        </script>
    {{/product}}
</div>

<script>
    async function loadTab(type, element, productId) {
        document.querySelectorAll('.product-tab-nav li').forEach(li => li.classList.remove('active'));
        element.classList.add('active');

        const contentArea = document.getElementById('tab-content');

        if (type === 'description') {
            contentArea.innerHTML = document.getElementById('origin-description').innerHTML;
        } else if (type === 'review') {
            try {
                contentArea.innerHTML = '<div class="loading">리뷰를 가져오는 중입니다.</div>';

                const [ratingResponse, reviewResponse] = await Promise.all([
                    fetch(`/products/${productId}/statistics`),
                    fetch(`/products/${productId}/reviews`)
                ]);

                if (ratingResponse.ok && reviewResponse.ok) {
                    const ratingHtml = await ratingResponse.text();
                    const reviewHtml = await reviewResponse.text();

                    contentArea.innerHTML = ratingHtml + reviewHtml;
                } else {
                    contentArea.innerHTML = '리뷰를 불러오지 못하였습니다.';
                }
            } catch (error) {
                contentArea.innerHTML = '오류 발생';
                throw new Error("오류 발생");
            }
        }
    }

    function changeQty(quantity) {
        const $quantity = document.getElementById('quantity');
        const $totalQty = document.getElementById('total-qty');
        const $totalPrice = document.getElementById('total-price');

        let currentQty = parseInt($quantity.value, 10);
        let currentPrice = parseInt($totalPrice.dataset.price, 10);

        const nextQty = currentQty + quantity;
        if (nextQty <= 0) return;
        $quantity.value = nextQty;
        $totalQty.textContent = nextQty;

        const nextPrice = currentPrice * nextQty;
        $totalPrice.textContent = nextPrice.toLocaleString()
    }

    const cartBtn = document.querySelector('.cart-btn');

    cartBtn.addEventListener('click', () => {
        const productId = cartBtn.dataset.productId;
        const quantity = document.getElementById('quantity').value;

        addCart(productId, quantity);
    })

    async function addCart(productId, quantity) {

        const response =  await fetch('/cart/add', {
            method: 'POST',
            headers: {
                'Content-Type':'application/json'
            },
            body: JSON.stringify({
                productId,
                quantity
            })
        });

        if (!response.ok) {
            alert("오류가 발생하였습니다.");
        } else {
            alert("장바구니에 상품을 담았습니다.");
        }
    }
</script>

<style>
    /* 상세 설명 영역 */
    .product-detail-content {
        max-width: 100%;
        overflow: hidden;
        line-height: 1.7;
        font-size: 15px;
        color: #333;
    }

    /* 에디터 이미지 */
    .product-detail-content img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 16px auto;
        object-fit: contain;
    }

    /* 혹시 모를 테이블/코드 대응 */
    .product-detail-content table {
        max-width: 100%;
    }

    .product-detail-content pre {
        white-space: pre-wrap;
        word-break: break-word;
    }

    .content-left {
        min-width: 0;
    }

    .main-image-area {
        width: 100%;
        max-width: 600px;
        overflow: hidden;
    }

    .main-image-area img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
    }

</style>


{{> layout/footer }}



