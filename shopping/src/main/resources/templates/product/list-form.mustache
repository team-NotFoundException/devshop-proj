<div class="header-wrapper">
    <div class="container">
        {{> layout/header }}
    </div>
</div>

<div class="dashboard-wrapper">
    {{> layout/owner-sidebar}}

    <div class="content-area">
        <h2 class="mb-4">상품 목록</h2>

        <div class="mb-3 text-end">
            <a href="/products/save" class="btn btn-primary">+ 상품 등록</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>상품명</th>
                        <th>가격</th>
                        <th>재고</th>
                        <th>상태</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#products}}
                        <tr>
                            <td>{{id}}</td>
                            <td>
                                <a href="/products/{{id}}/detail" class="text-decoration-none fw-bold">{{productName}}</a>
                            </td>
                            <td>{{price}}원</td>
                            <td>{{stockQuantity}}</td>
                            <td><span class="badge bg-info">{{status}}</span></td>
                        </tr>
                    {{/products}}
                    {{^products}}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">등록된 상품이 없습니다.</td>
                        </tr>
                    {{/products}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{{> layout/footer }}