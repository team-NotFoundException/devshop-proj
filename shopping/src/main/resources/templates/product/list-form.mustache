{{> layout/header }}

<!-- 사이드바 + 컨텐츠 Flex 컨테이너 -->
<div class="dashboard-wrapper" style="display: flex; min-height: 100vh; gap: 20px;">

    <!-- 사이드바 -->
    {{> layout/owner-sidebar}}

    <!-- 컨텐츠 영역 -->
    <div class="content-area" style="flex: 1; padding: 20px; max-width: 1400px;">
        <div class="page-header">
            <h2>상품 목록</h2>
            <a href="/owner/products/save" class="btn-add">
                <i class="bi bi-plus-lg"></i>
                상품 등록
            </a>
        </div>

        <!-- 검색 폼 -->
        <div class="search-container">
            <form action="/owner/products/search" method="get" class="search-form">
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text"
                           name="keyword"
                           class="search-input"
                           placeholder="상품명으로 검색하세요..."
                           value="{{keyword}}">
                    <button type="submit" class="search-btn">검색</button>
                </div>
            </form>
        </div>

        <!-- 검색 결과 표시 -->
        {{#keyword}}
            <div class="search-result-info">
                <div class="result-text">
                    <i class="bi bi-search"></i>
                    <span>"<strong>{{keyword}}</strong>" 검색 결과</span>
                </div>
                <a href="/owner/products" class="btn-reset">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    전체 목록
                </a>
            </div>
        {{/keyword}}

        <!-- 상품 테이블 -->
        <div class="table-container">
            <table class="product-table">
                <thead>
                <tr>
                    <th width="80">ID</th>
                    <th>상품명</th>
                    <th width="150">가격</th>
                    <th width="100">재고</th>
                    <th width="120">상태</th>
                </tr>
                </thead>
                <tbody>
                {{#products}}
                    <tr class="product-row">
                        <td class="id-cell">{{id}}</td>
                        <td class="name-cell">
                            <a href="/owner/products/{{id}}" class="product-link">{{productName}}</a>
                        </td>
                        <td class="price-cell">{{price}}원</td>
                        <td class="stock-cell">{{stockQuantity}}</td>
                        <td class="status-cell">
                            <span class="status-badge status-{{status}}">{{status}}</span>
                        </td>
                    </tr>
                {{/products}}
                {{^products}}
                    <tr>
                        <td colspan="5" class="empty-cell">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <p>
                                    {{#keyword}}
                                        검색 결과가 없습니다.
                                    {{/keyword}}
                                    {{^keyword}}
                                        등록된 상품이 없습니다.
                                    {{/keyword}}
                                </p>
                            </div>
                        </td>
                    </tr>
                {{/products}}
                </tbody>
            </table>
        </div>
    </div>


</div>

{{> layout/footer }}