{{> layout/header }}

<!-- 사이드바 + 컨텐츠 Flex 컨테이너 -->
<div class="dashboard-wrapper" style="display: flex; min-height: 100vh; gap: 20px;">

    <!-- 사이드바 -->
    {{> layout/owner-sidebar}}

    <!-- 컨텐츠 영역 -->
    <div class="content-area" style="flex: 1; padding: 20px;">
        <h2 class="mb-4">상품 목록</h2>

        <div class="mb-3 text-end">
            <a href="/owner/products/save" class="btn btn-primary">+ 상품 등록</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>상품명</th>
                        <th>가격</th>
                        <th>재고</th>
                        <th>상태</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#products}}
                        <tr>
                            <td>{{id}}</td>
                            <td>
                                <a href="/owner/products/{{id}}" class="text-decoration-none fw-bold">{{productName}}</a>
                            </td>
                            <td>{{price}}원</td>
                            <td>{{stockQuantity}}</td>
                            <td><span class="badge bg-info">{{status}}</span></td>
                        </tr>
                    {{/products}}
                    {{^products}}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">등록된 상품이 없습니다.</td>
                        </tr>
                    {{/products}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

{{> layout/footer }}