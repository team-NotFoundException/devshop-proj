<div class="header-wrapper has-nav">
    <div class="container">
        {{> layout/header }}
        {{> layout/nav }}
    </div>
</div>

<div class="container p-5">
    <h2 class="mb-4">상품 목록</h2>

    <div class="mb-3 text-end">
        <a href="/products/save" class="btn">+ 상품 등록</a>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
        <tr>
            <th>ID</th>
            <th>상품명</th>
            <th>썸네일</th>
            <th>가격</th>
            <th>재고</th>
            <th>상태</th>
        </tr>
        </thead>

        {{#products}}
            <tr>
                <td>{{id}}</td>
                <td><a href="/products/{{id}}/detail">{{productName}}</a></td>
                <td>
                    {{#thumbnailUrl}}
                        <img src="{{thumbnailUrl}}" alt="{{productName}}" width="100">
                    {{/thumbnailUrl}}
                    {{^thumbnailUrl}}
                        없음
                    {{/thumbnailUrl}}
                </td>
                <td>{{price}}</td>
                <td>{{stockQuantity}}</td>
                <td>{{status}}</td>
            </tr>
        {{/products}}
    </table>
    {{^products}}
        <p class="text-center text-muted">등록된 상품이 없습니다.</p>
    {{/products}}
</div>

{{> layout/footer }}