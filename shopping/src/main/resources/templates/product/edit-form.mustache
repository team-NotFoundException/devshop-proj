{{> layout/header }}

<div class="dashboard-wrapper" style="display: flex; min-height: 100vh; gap: 20px;">
    {{> layout/owner-sidebar}}

    <div class="content-area" style="flex: 1; padding: 20px;">
        <div class="card shadow-sm" style="max-width: 900px; margin: auto;">
            <div class="card-body p-5">
                <h2 class="mb-4 text-warning">상품 정보 수정</h2>

                <form action="/owner/products/{{product.id}}/edit" method="post" id="editForm" enctype="multipart/form-data">


                    {{#product.thumbnailUrl}}
                        <input type="hidden" name="existingThumbnail" value="{{product.thumbnailUrl}}">
                    {{/product.thumbnailUrl}}

                    <div class="mb-3">
                        <label class="form-label fw-bold">카테고리</label>
                        <select name="categoryId" class="form-select" required>
                            {{#category}}
                                <option value="{{id}}" {{#isSelected}}selected{{/isSelected}}>
                                    {{categoryName}}
                                </option>
                            {{/category}}
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">상품명</label>
                        <input type="text" name="productName" class="form-control"
                               value="{{product.productName}}" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">판매 가격</label>
                        <input type="number" name="price" class="form-control"
                               value="{{product.price}}" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">재고 수량</label>
                        <input type="number" name="stockQuantity" class="form-control"
                               value="{{product.stockQuantity}}" min="0" required>
                    </div>


                    {{#product.thumbnailUrl}}
                        <div class="current-thumbnail mb-2">
                            <p class="text-muted small">현재 썸네일:</p>
                            <!-- getThumbnailDisplayUrl() 메서드 사용 -->
                            <img src="{{product.thumbnailDisplayUrl}}" alt="현재 썸네일"
                                 style="max-width: 200px; border-radius: 8px;">
                        </div>
                        <!-- 기존 썸네일 URL을 hidden으로 유지 (DB 저장용 원본) -->
                        <input type="hidden" name="existingThumbnail" value="{{product.thumbnailUrl}}">
                    {{/product.thumbnailUrl}}
                    <input type="file" name="thumbnail" class="form-control" accept="image/*" id="thumbnailInput" required>
                        <small class="text-muted">새 이미지를 선택하면 기존 썸네일이 교체됩니다. 선택하지 않으면 기존 썸네일이 유지됩니다.</small>


                        <div id="thumbnailPreview" class="mt-2" style="display: none;">
                            <p class="text-muted small">새 썸네일 미리보기:</p>
                            <img id="previewImage" style="max-width: 200px; border-radius: 8px;">
                        </div>




                    <div class="mb-3">
                        <label class="form-label fw-bold">상품 설명</label>
                        <div id="editor"></div>
                        <input type="hidden" name="description" id="description">
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">판매 상태</label>
                        <select name="status" class="form-select" required>
                            <option value="ACTIVE" {{#product.active}}selected{{/product.active}}>판매중</option>
                            <option value="SOLD_OUT" {{#product.soldOut}}selected{{/product.soldOut}}>품절</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="/owner/products" class="btn btn-secondary">취소</a>
                        <button type="submit" class="btn btn-warning px-5 fw-bold">수정 완료</button>
                    </div>
                </form>

                <hr class="my-5">

                <div class="bg-light p-3 rounded d-flex justify-content-between align-items-center">
                    <span class="text-danger small fw-bold">
                        상품 삭제 시 복구가 불가능합니다.
                    </span>
                    <form action="/owner/products/{{product.id}}/delete" method="post"
                          onsubmit="return confirm('정말 삭제하시겠습니까?');">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            상품 삭제
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css" />
<script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>

<script>
    const editor = new toastui.Editor({
        el: document.querySelector('#editor'),
        height: '400px',
        initialEditType: 'wysiwyg',
        initialValue: `{{{product.description}}}`
    });

    document.querySelector('#editForm').addEventListener('submit', function () {
        document.querySelector('#description').value = editor.getHTML();
    });


    document.getElementById('thumbnailInput').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('previewImage').src = e.target.result;
                document.getElementById('thumbnailPreview').style.display = 'block';
            };
            reader.readAsDataURL(file);
        } else {
            document.getElementById('thumbnailPreview').style.display = 'none';
        }
    });
</script>

{{> layout/footer }}